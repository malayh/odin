# Copy to .env and fill in. Loaded by the backend (pydantic-settings) and the worker.

# --- Database (Postgres + pgvector + Apache AGE) ---
DATABASE_URL=postgresql+psycopg://odin:odin@localhost:25000/odin
AGE_GRAPH=odin

# --- Blob store (MinIO in dev). boto3 reads the AWS_* creds directly. ---
S3_ENDPOINT_URL=http://localhost:25001
S3_BUCKET=odin
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=supersecret

# --- LLM (OpenAI-compatible via OpenRouter; repointable to OpenAI) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ANSWER_MODEL=z-ai/glm-5.2

# --- Embeddings ---
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
