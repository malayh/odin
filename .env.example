# Copy to .env and fill in. Loaded by the backend (pydantic-settings) and the worker.

# --- Database (Postgres + pgvector + Apache AGE) ---
DATABASE_URL=postgresql+asyncpg://odin:odin@localhost:5432/odin
AGE_GRAPH=odin

# --- Blob store (MinIO in dev). boto3 reads the AWS_* creds directly. ---
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=odin
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# --- AI providers (cloud-only) ---
ANTHROPIC_API_KEY=
ANSWER_MODEL=claude-opus-4-8
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
